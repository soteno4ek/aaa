#include <iostream>
#include <string>

using namespace std;

struct TreeNode {
    int val;
    TreeNode* left;
    TreeNode* right;
    TreeNode(int x) : val(x), left(nullptr), right(nullptr) {}
};

typedef TreeNode* Pnode;

string treeToString(Pnode root) {
    if (root == nullptr) {
        return "";
    }
    
    string leftStr = treeToString(root->left);
    string rightStr = treeToString(root->right);
    
    if (!leftStr.empty() && !rightStr.empty()) {
        return "(" + leftStr + ")" + to_string(root->val) + "(" + rightStr + ")";
    }
    else if (!leftStr.empty()) {
        return "(" + leftStr + ")" + to_string(root->val);
    }
    else if (!rightStr.empty()) {
        return to_string(root->val) + "(" + rightStr + ")";
    }
    else {
        return to_string(root->val);
    }
}

void del(Pnode &r, Pnode &q) {
    if (r->right) {
        del(r->right, q);
    }
    else {
        q->val = r->val;
        q = r;
        r = r->left;
    }
}

void deleteNode(Pnode &root, int K) {
    if (!root) return;
    
    if (K < root->val) {
        deleteNode(root->left, K);
    }
    else if (K > root->val) {
        deleteNode(root->right, K);
    }
    else {
        Pnode q = root;
        
        if (!root->right) {
            root = root->left;
        }
        else if (!root->left) {
            root = root->right;
        }
        else {
            del(root->right, q);
        }
        
        delete q;
    }
}

int main() {
    Pnode root = new TreeNode(35);
    root->left = new TreeNode(28);
    root->right = new TreeNode(86);
    root->right->left = new TreeNode(81);
    root->right->right = new TreeNode(90);
    root->right->left->left = new TreeNode(41);
    root->right->left->left->right = new TreeNode(51);
    root->right->left->left->right->right = new TreeNode(55);
    
    cout << "Исходное дерево: " << treeToString(root) << endl;
    cout << endl;
    
    int toDelete[] = {51, 86, 35};
    
    for (int i = 0; i < 3; i++) {
        int K = toDelete[i];
        cout << "Удаляем " << K << ":" << endl;
        deleteNode(root, K);
        cout << treeToString(root) << endl;
        cout << endl;
    }
    
    return 0;
}
