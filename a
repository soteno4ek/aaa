#include <iostream>
#include <fstream>
#include <queue>
#include <vector>

using namespace std;

struct TreeNode {
    int val;
    TreeNode* left;
    TreeNode* right;
    TreeNode(int x) : val(x), left(nullptr), right(nullptr) {}
};

vector<int> getLevelNodes(TreeNode* root, int N) {
    vector<int> result;
    if (!root || N < 1) return result;
    
    queue<pair<TreeNode*, int>> q;
    q.push({root, 1});
    
    while (!q.empty()) {
        TreeNode* current = q.front().first;
        int level = q.front().second;
        q.pop();
        
        if (level == N) {
            result.push_back(current->val);
        }
        
        if (current->left) {
            q.push({current->left, level + 1});
        }
        if (current->right) {
            q.push({current->right, level + 1});
        }
    }
    
    return result;
}

void printLevels(TreeNode* root, const string& filename) {
    if (!root) return;
    
    ofstream out(filename);
    
    queue<TreeNode*> q;
    q.push(root);
    
    while (!q.empty()) {
        int levelSize = q.size();
        
        for (int i = 0; i < levelSize; i++) {
            TreeNode* current = q.front();
            q.pop();
            
            out << current->val;
            
            if (i < levelSize - 1) {
                out << " ";
            }
            
            if (current->left) {
                q.push(current->left);
            }
            if (current->right) {
                q.push(current->right);
            }
        }
        
        if (!q.empty()) {
            out << endl;
        }
    }
    
    out.close();
}

int main() {
    TreeNode* root = new TreeNode(75);
    root->left = new TreeNode(67);
    root->right = new TreeNode(28);
    root->left->left = new TreeNode(94);
    root->left->right = new TreeNode(87);
    root->right->left = new TreeNode(80);
    root->right->right = new TreeNode(1);
    root->left->left->left = new TreeNode(95);
    root->left->right->left = new TreeNode(48);
    root->left->right->right = new TreeNode(50);
    
    printLevels(root, "kc49e.tst");
    
    return 0;
}
